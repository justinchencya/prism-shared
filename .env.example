# Copy to .env and fill in. .env is gitignored.
# Loaded automatically by scripts/tts_synthesize.py and scripts/fetch_signals.py
# from the repo root.

# OpenAI — used by /podcast for text-to-speech (gpt-4o-mini-tts).
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# SEC EDGAR contact email — SEC requires a contact address in the User-Agent of
# EDGAR requests (scripts/fetch_signals.py, scripts/fetch_ticker_stats.py, and the
# researcher's curl examples). Use your own email. Falls back to a generic
# placeholder if unset, but setting it is polite and avoids rate-limit issues.
EDGAR_CONTACT_EMAIL=you@example.com

# X — used by /scout to pull recent posts from your curated follow list
# (.claude/scout-x-feeds.json) as a signal source. App-only Bearer Token from a
# project with user-timeline read access (GET /2/users/:id/tweets).
# If unset, /scout simply skips the X source and runs on GDELT/HN/EDGAR as before.
# Get one at https://developer.x.com → Projects & Apps → Keys and tokens.
X_BEARER_TOKEN=

# Notion — used by /log-trade (write) and /scout (read) for the Investment Log database.
# 1. Go to https://www.notion.so/my-integrations → New integration (Internal)
# 2. Copy the "Internal Integration Secret" (starts with ntn_...)
# 3. In the Investment Log database: ··· → Connections → add your integration
# 4. Paste the secret below
# If unset, /log-trade records trades locally only and /scout skips the Notion read —
# both degrade gracefully, so Notion is fully optional.
NOTION_TOKEN=ntn_...

# Your Investment Log database identifiers. The engine reads these from the env so no
# personal IDs are hardcoded in the prompts. To find them, open the database in Notion
# (or let the integration search for a database named "Investment Log"). If these are
# unset but NOTION_TOKEN is configured, the engine falls back to resolving the DB by
# that name.
#   - data_source_id: used for query / create / schema calls (/log-trade)
#   - database_id:    parent container, used by /scout's read
NOTION_INVESTMENT_LOG_DATA_SOURCE_ID=
NOTION_INVESTMENT_LOG_DATABASE_ID=
