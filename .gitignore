.DS_Store
.env

# Podcast TTS segments are intermediate build artifacts — deleted after a
# successful stitch. This backstops a failed/partial run from committing them.
reports/**/podcast/segments/

# Python bytecode cache from scripts/.
__pycache__/

# Daily-close price cache written by scripts/generate_dashboard.py — pure
# regenerable optimization, refetched whole per ticker per day.
tracking/price-cache.json

